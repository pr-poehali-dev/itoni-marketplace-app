{
  "tests": [
    {
      "name": "Magic request invalid email",
      "method": "POST",
      "path": "/",
      "body": {"action": "magic_request", "email": "notanemail"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Magic verify no token",
      "method": "POST",
      "path": "/",
      "body": {"action": "magic_verify", "token": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Magic verify invalid token",
      "method": "POST",
      "path": "/",
      "body": {"action": "magic_verify", "token": "invalid.token.here"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Set phone unauthorized",
      "method": "POST",
      "path": "/",
      "body": {"action": "set_phone", "phone": "+79991234567"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Magic verify code invalid length",
      "method": "POST",
      "path": "/",
      "body": {"action": "magic_verify_code", "email": "user@mail.ru", "code": "123"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Magic verify code wrong code",
      "method": "POST",
      "path": "/",
      "body": {"action": "magic_verify_code", "email": "nobody@mail.ru", "code": "000000"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Magic request real send (diagnostic)",
      "method": "POST",
      "path": "/",
      "body": {"action": "magic_request", "email": "muratdzaurov@mail.ru"},
      "expectedStatus": 200,
      "expectedBody": {"message": "string"},
      "bodyMatcher": "partial"
    }
  ]
}