{
  "tests": [
    {
      "name": "Register requires long password",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "login": "ab", "password": "123"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong credentials",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "login": "nouser_xyz", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Email send invalid email",
      "method": "POST",
      "path": "/",
      "body": {"action": "email_send", "email": "notanemail"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Email verify wrong code",
      "method": "POST",
      "path": "/",
      "body": {"action": "email_verify", "email": "test@example.com", "code": "0000"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
